+        # V4L2 controls applied to the USB camera at pipeline start. Comma-separated
+        # "name=value"; empty string leaves the camera in its stock (all-auto) state.
+        #
+        # exposure_absolute is deliberately absent: the C920e on this board rejects
+        # every value (EILSEQ), so exposure cannot be chosen, only frozen where the
+        # camera's own AE left it. Use gain to trim brightness instead.
+        self.declare_parameter(
+            'v4l2_extra_controls',
+            'exposure_auto=1,'
+            'exposure_auto_priority=0,'
+            'white_balance_temperature_auto=0,'
