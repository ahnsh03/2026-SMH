+    def build_v4l2_source(self, camera_device):
+        """v4l2src with the configured V4L2 controls applied at pipeline start.
+
+        The controls must ride on the element: this node opens the camera through
+        cv2.CAP_GSTREAMER, and OpenCV's cap.set(cv2.CAP_PROP_*) is a silent no-op
+        on the GStreamer backend.
+        """
+        source = f"v4l2src device={camera_device} io-mode=2"
+        if self.v4l2_extra_controls:
+            source += f' extra-controls="c,{self.v4l2_extra_controls}"'
+        return source
